# Server
NODE_ENV=development
PORT=3001

# Database (matches docker-compose.yml in repo root)
DATABASE_URL=postgresql://postgres:devpass@localhost:5432/flooring_platform

# JWT — generate a real secret for production:  openssl rand -base64 64
JWT_SECRET=replace-me-with-a-long-random-string-for-production
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d

# CORS — comma-separated origins for the web app
CORS_ORIGINS=http://localhost:3000
